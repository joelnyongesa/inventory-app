# Version control
.git
.gitignore
.gitattributes

# Node
node_modules

# PHP dependencies (built in composer stage)
vendor

# Built frontend (built in node stage)
public/build
public/hot

# Laravel runtime files (not needed in image)
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*

# Local environment (never bake secrets into image)
.env
.env.*
!.env.example

# Development / test only
tests
phpunit.xml
*.test
*.spec

# Editor & OS
.idea
.vscode
*.DS_Store
Thumbs.db

# Docker config itself (already on build host)
docker-compose*.yml
